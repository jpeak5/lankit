<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ household_name | default('Home') }} network</title>
  <style>
    :root { --bg:#f8fafc; --surface:#fff; --text:#1e293b; --muted:#64748b; --accent:#2563eb; --border:#e2e8f0; --radius:8px; }
    * { box-sizing:border-box; margin:0; padding:0; }
    body { font-family:system-ui,-apple-system,sans-serif; background:var(--bg); color:var(--text); max-width:620px; margin:0 auto; padding:1.5rem 1rem 3rem; font-size:15px; line-height:1.55; }
    header { margin-bottom:1.25rem; }
    header h1 { font-size:1.15rem; font-weight:700; }
    header p { color:var(--muted); font-size:0.85rem; margin-top:0.15rem; }
    .card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:1rem 1.1rem; margin-bottom:0.75rem; }
    a { color:var(--accent); text-decoration:none; font-weight:500; }
    a:hover { text-decoration:underline; }
    .desc { color:var(--muted); font-size:0.875rem; margin-top:0.2rem; }
  </style>
</head>
<body>
  <header>
    <h1>{{ household_name | default('Home') }} network</h1>
    <p>apps.{{ lankit_internal_domain }}</p>
  </header>

  <div class="card">
    <a href="http://me.{{ lankit_internal_domain }}">me.{{ lankit_internal_domain }}</a>
    <p class="desc">See your device's ad-blocking stats, or pause it for a while.</p>
  </div>

  {% if lankit_portals.get('network') %}
  <div class="card">
    <a href="http://network.{{ lankit_internal_domain }}">network.{{ lankit_internal_domain }}</a>
    <p class="desc">Check if the internet is working and see what devices are online.</p>
  </div>
  {% endif %}

  {% if lankit_portals.get('registration') %}
  <div class="card">
    <a href="http://register.{{ lankit_internal_domain }}">register.{{ lankit_internal_domain }}</a>
    <p class="desc">Name a new device so the network remembers it.</p>
  </div>
  {% endif %}
</body>
</html>
