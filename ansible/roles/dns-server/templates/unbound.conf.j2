# unbound.conf — Pi-hole companion recursive resolver
# Generated by lankit — do not edit directly
#
# Architecture: Unbound binds to localhost only. Pi-hole is the only
# listener on port 53. All VLANs route DNS to Pi-hole; Pi-hole
# forwards to Unbound at 127.0.0.1:5335 for full recursive resolution.
# Unbound never sees VLAN interfaces — the router handles all routing.
#
# This single-interface design is the key to reliability: adding or
# removing VLANs requires no changes to this file.

server:
    # Bind to localhost only — Pi-hole is the public face of DNS
    interface: 127.0.0.1
    port: 5335
    do-ip4: yes
    do-ip6: no
    do-udp: yes
    do-tcp: yes

    # Only accept queries from Pi-hole on localhost
    access-control: 127.0.0.0/8 allow
    access-control: 0.0.0.0/0 refuse

    # Security hardening
    harden-glue: yes
    harden-dnssec-stripped: yes
    harden-below-nxdomain: yes
    harden-referral-path: no
    use-caps-for-id: no

    # Privacy: send minimal query info upstream (RFC 7816)
    qname-minimisation: yes

    # EDNS buffer size (recommended for modern resolvers)
    edns-buffer-size: 1232

    # Performance: cache tuning for a home Pi
    prefetch: yes
    prefetch-key: yes
    num-threads: 2
    msg-cache-slabs: 4
    rrset-cache-slabs: 4
    infra-cache-slabs: 4
    key-cache-slabs: 4
    rrset-cache-size: 64m
    msg-cache-size: 32m
    neg-cache-size: 4m

    # Root hints for full recursion (no forwarder — we go to the roots)
    root-hints: "/var/lib/unbound/root.hints"

    # Logging — keep minimal for a home device
    verbosity: 0
    log-queries: no
    log-replies: no
