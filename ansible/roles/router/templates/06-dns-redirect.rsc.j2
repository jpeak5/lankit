# 06-dns-redirect.rsc — Force DNS to Pi-hole for segments with force_dns: true
# Generated by lankit — do not edit directly
#
# Intercepts all port-53 traffic from force_dns segments and redirects
# it to Pi-hole, regardless of what DNS server the device has hardcoded.
# This ensures IoT devices (and others) cannot bypass Pi-hole by
# using 8.8.8.8 or any other external resolver.
#
# Skipped entirely when no Pi-hole host is configured — redirecting to a
# public DNS IP defeats the purpose of force_dns.

{% set has_redirect = namespace(value=false) %}
{% for name, seg in segments.items() %}{% if seg.force_dns %}{% set has_redirect.value = true %}{% endif %}{% endfor %}

{% if has_redirect.value and dns_server_segment is not none %}
/ip firewall nat

{% for name, seg in segments.items() %}
{% if seg.force_dns %}
# {{ name }}: redirect UDP/53 to Pi-hole
add chain=dstnat \
    src-address-list=net-{{ name }} \
    dst-port=53 protocol=udp \
    action=dst-nat \
    to-addresses={{ dns_server_ip }} \
    to-ports=53 \
    comment="kit:fw:{{ name }}:dns-redirect-udp"

# {{ name }}: redirect TCP/53 to Pi-hole
add chain=dstnat \
    src-address-list=net-{{ name }} \
    dst-port=53 protocol=tcp \
    action=dst-nat \
    to-addresses={{ dns_server_ip }} \
    to-ports=53 \
    comment="kit:fw:{{ name }}:dns-redirect-tcp"
{% endif %}
{% endfor %}

{% else %}
# No segments have force_dns: true — no redirect rules generated.
{% endif %}
