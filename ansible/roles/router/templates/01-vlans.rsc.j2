# 01-vlans.rsc — VLAN interfaces and bridge configuration
# Generated by lankit — do not edit directly
#
# Creates VLAN infrastructure on the bridge. All VLANs are tagged
# on the CPU port (bridge). The DNS server port gets tagged on every
# VLAN that uses it for DNS, so it can serve all segments.
#
# IMPORTANT: VLAN filtering is enabled at the end of this script.
# Run this LAST, after all other VLAN resources are defined, or
# you will lose access to the router.

# ── Remove previously managed entries (idempotent re-apply) ─────────────────
{% if include_globals %}
:foreach i in=[/interface vlan find where comment~"^lankit:vlan:"] do={ /interface vlan remove $i }
:foreach i in=[/interface bridge vlan find where comment~"^lankit:vlan:"] do={ /interface bridge vlan remove $i }
{% else %}
{% for name in segments %}
:foreach i in=[/interface vlan find where comment~"^lankit:vlan:{{ name }}:"] do={ /interface vlan remove $i }
:foreach i in=[/interface bridge vlan find where comment~"^lankit:vlan:{{ name }}:"] do={ /interface bridge vlan remove $i }
{% endfor %}
{% endif %}

# ── VLAN interfaces on the bridge ───────────────────────────────────────────
{% for name, seg in segments.items() %}
/interface vlan
add interface=bridge \
    name=vlan-{{ name }} \
    vlan-id={{ seg.vlan_id }} \
    comment="lankit:vlan:{{ name }}:interface"
{% endfor %}

# ── Bridge VLAN table — all VLANs tagged on CPU port ────────────────────────
{% for name, seg in segments.items() %}
/interface bridge vlan
add bridge=bridge \
    tagged=bridge \
    vlan-ids={{ seg.vlan_id }} \
    comment="lankit:vlan:{{ name }}:bridge"
{% endfor %}

{% if include_globals %}
# ── Legacy flat network (PVID 1) — keep running during migration ─────────────
# ether3-5 remain on PVID 1 for unassigned wired devices.
# lan_interface (DNS server port) gets its own PVID below.
/interface bridge vlan
add bridge=bridge \
    vlan-ids=1 \
    tagged=bridge \
    untagged=ether3,ether4,ether5 \
    comment="lankit:vlan:legacy:flat"

# ── Reset PVIDs to 1 on unassigned LAN ports ────────────────────────────────
/interface bridge port
{% for port in ['ether3', 'ether4', 'ether5'] %}
set [find where interface={{ port }}] pvid=1
{% endfor %}

{% if dns_server_vlan_id is not none %}
# ── DNS server port: untagged access to servers VLAN ────────────────────────
# The Pi sends untagged frames; the bridge tags them to VLAN {{ dns_server_vlan_id }}.
# Cross-VLAN DNS queries are handled by routing, not by tagging ether2 on every VLAN.
/interface bridge port
set [find where interface={{ lan_interface }}] pvid={{ dns_server_vlan_id }}
/interface bridge vlan
set [find where vlan-ids={{ dns_server_vlan_id }}] untagged={{ lan_interface }}
{% endif %}

# ── Enable VLAN filtering — do this LAST ────────────────────────────────────
/interface bridge
set bridge vlan-filtering=yes
{% endif %}
