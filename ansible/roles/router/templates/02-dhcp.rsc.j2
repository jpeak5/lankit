# 02-dhcp.rsc — IP addresses and DHCP servers per segment
# Generated by lankit — do not edit directly

# ── Gateway IPs on each VLAN interface ──────────────────────────────────────
{% for name, seg in segments.items() %}
/ip address
add address={{ seg.gateway }}/24 \
    interface=vlan-{{ name }} \
    network={{ seg.subnet | replace('/24','') }} \
    comment="kit:dhcp:{{ name }}:address"
{% endfor %}

# ── DHCP pools ───────────────────────────────────────────────────────────────
{% for name, seg in segments.items() %}
/ip pool
add name=pool-{{ name }} \
    ranges={{ seg.pool_range }} \
    comment="kit:dhcp:{{ name }}:pool"
{% endfor %}

# ── DHCP servers ─────────────────────────────────────────────────────────────
{% for name, seg in segments.items() %}
/ip dhcp-server
add name=dhcp-{{ name }} \
    interface=vlan-{{ name }} \
    address-pool=pool-{{ name }} \
    lease-time=1h \
    disabled=no \
    comment="kit:dhcp:{{ name }}:server"
{% endfor %}

# ── DHCP networks (gateway + DNS per segment) ────────────────────────────────
{% for name, seg in segments.items() %}
/ip dhcp-server network
{% if seg.dns == 'filtered' %}
add address={{ seg.subnet }} \
    gateway={{ seg.gateway }} \
    dns-server={{ dns_server_ip }},{{ seg.gateway }} \
    comment="kit:dhcp:{{ name }}:network"
{% elif seg.dns == 'unfiltered' %}
add address={{ seg.subnet }} \
    gateway={{ seg.gateway }} \
    dns-server=1.1.1.1,8.8.8.8 \
    comment="kit:dhcp:{{ name }}:network"
{% else %}
{# dns == "none" — no DNS offered (quarantine) #}
add address={{ seg.subnet }} \
    gateway={{ seg.gateway }} \
    comment="kit:dhcp:{{ name }}:network"
{% endif %}
{% endfor %}

{% if include_globals %}
# ── Static leases: named hosts ───────────────────────────────────────────────
/ip dhcp-server lease
add address={{ dns_server_ip }} \
    mac-address={{ dns_server_mac }} \
    server=dhcp-{{ dns_server_segment }} \
    comment="kit:dhcp:dns-server:lease"
{% if app_server_ip %}
add address={{ app_server_ip }} \
    mac-address={{ app_server_mac }} \
    server=dhcp-{{ app_server_segment }} \
    comment="kit:dhcp:app-server:lease"
{% endif %}
{% endif %}
