# 07-bandwidth.rsc — Queue trees for segment bandwidth limits
# Generated by lankit — do not edit directly
#
# Only segments with bandwidth_up or bandwidth_down set get queues.
# Uses a simple PCQ (Per Connection Queue) approach suitable for
# home networks. The parent queue is the WAN interface.

{% set has_bw = namespace(value=false) %}
{% for name, seg in segments.items() %}{% if seg.bandwidth_up or seg.bandwidth_down %}{% set has_bw.value = true %}{% endif %}{% endfor %}

{% if has_bw.value %}

# ── Mangle: mark packets per segment for queue targeting ────────────────────
/ip firewall mangle
{% for name, seg in segments.items() %}
{% if seg.bandwidth_up or seg.bandwidth_down %}
add chain=forward \
    action=mark-packet \
    new-packet-mark={{ name }}-pkt \
    passthrough=no \
    src-address-list=net-{{ name }} \
    comment="kit:bw:{{ name }}:mark-upload"
add chain=forward \
    action=mark-packet \
    new-packet-mark={{ name }}-pkt-down \
    passthrough=no \
    dst-address-list=net-{{ name }} \
    comment="kit:bw:{{ name }}:mark-download"
{% endif %}
{% endfor %}

# ── Queue tree ───────────────────────────────────────────────────────────────
/queue tree
{% for name, seg in segments.items() %}
{% if seg.bandwidth_up %}
add name=bw-{{ name }}-up \
    parent={{ wan_interface }} \
    packet-mark={{ name }}-pkt \
    max-limit={{ seg.bandwidth_up }} \
    comment="kit:bw:{{ name }}:up"
{% endif %}
{% if seg.bandwidth_down %}
add name=bw-{{ name }}-down \
    parent=global \
    packet-mark={{ name }}-pkt-down \
    max-limit={{ seg.bandwidth_down }} \
    comment="kit:bw:{{ name }}:down"
{% endif %}
{% endfor %}

{% else %}
# No segments have bandwidth limits configured — no queue rules generated.
{% endif %}
