# 05-dns.rsc — Static DNS entries for segment infrastructure
# Generated by lankit — do not edit directly
#
# These entries ensure .internal names resolve via the router's DNS,
# providing a fallback if the Pi-hole is temporarily unreachable.

/ip dns static
# Remove previously managed entries (full apply: all; segment mode: this segment only)
{% if include_globals %}
:foreach i in=[/ip dns static find where comment~"^lankit:dns:"] do={ /ip dns static remove $i }
{% else %}
{% for name in segments %}
:foreach i in=[/ip dns static find where comment~"^lankit:dns:{{ name }}:"] do={ /ip dns static remove $i }
{% endfor %}
{% endif %}

{% for name, seg in segments.items() %}
add name={{ name }}.{{ internal_domain }} \
    address={{ seg.gateway }} \
    ttl=1h type=A \
    comment="lankit:dns:{{ name }}:gateway"
{% endfor %}

{% if include_globals %}
{% if dns_server_segment is not none %}
# Service hostnames
add name=dns.{{ internal_domain }} \
    address={{ dns_server_ip }} \
    ttl=1h type=A \
    comment="lankit:dns:dns-server:hostname"
add name=pihole.{{ internal_domain }} \
    address={{ dns_server_ip }} \
    ttl=1h type=A \
    comment="lankit:dns:pihole:hostname"
{% endif %}
{% if app_server_ip %}
add name=apps.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="lankit:dns:app-server:hostname"
add name=me.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="lankit:dns:portal-me:hostname"
add name=network.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="lankit:dns:portal-network:hostname"
add name=register.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="lankit:dns:portal-register:hostname"
{% endif %}
{% endif %}
