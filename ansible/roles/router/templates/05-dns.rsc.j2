# 05-dns.rsc — Static DNS entries for segment infrastructure
# Generated by lankit — do not edit directly
#
# These entries ensure .internal names resolve via the router's DNS,
# providing a fallback if the Pi-hole is temporarily unreachable.

/ip dns static
# Remove all previously managed entries so this script is idempotent
:foreach i in=[/ip dns static find where comment~"^kit:dns:"] do={ /ip dns static remove $i }

{% for name, seg in segments.items() %}
add name={{ name }}.{{ internal_domain }} \
    address={{ seg.gateway }} \
    ttl=1h type=A \
    comment="kit:dns:{{ name }}:gateway"
{% endfor %}

{% if include_globals %}
# Service hostnames
add name=dns.{{ internal_domain }} \
    address={{ dns_server_ip }} \
    ttl=1h type=A \
    comment="kit:dns:dns-server:hostname"
add name=pihole.{{ internal_domain }} \
    address={{ dns_server_ip }} \
    ttl=1h type=A \
    comment="kit:dns:pihole:hostname"
{% if app_server_ip %}
add name=apps.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="kit:dns:app-server:hostname"
add name=me.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="kit:dns:portal-me:hostname"
add name=network.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="kit:dns:portal-network:hostname"
add name=register.{{ internal_domain }} \
    address={{ app_server_ip }} \
    ttl=1h type=A \
    comment="kit:dns:portal-register:hostname"
{% endif %}
{% endif %}
