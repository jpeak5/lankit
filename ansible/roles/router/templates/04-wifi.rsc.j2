# 04-wifi.rsc — WiFi SSIDs mapped to segments
# Generated by lankit — do not edit directly
#
# Strategy:
#   - Master interfaces hidden and renamed to prevent direct association
#     (MikroTik: changing PVID on masters corrupts internal WiFi state)
#   - All SSIDs are virtual APs on top of the masters
#   - Same SSID + passphrase on both bands = seamless band-steering

{% if include_globals %}
# ── Hide master interfaces ───────────────────────────────────────────────────
/interface wifi
set wifi1 \
    configuration.ssid="_master-5g-noconnect" \
    configuration.hide-ssid=yes
set wifi2 \
    configuration.ssid="_master-2g-noconnect" \
    configuration.hide-ssid=yes
{% endif %}

# ── Security profiles ────────────────────────────────────────────────────────
{% for name, seg in segments.items() %}
{% if seg.has_wifi %}
/interface wifi security
add name=sec-{{ name }} \
    authentication-types=wpa2-psk{% if '5ghz' in seg.wifi_bands %},wpa3-psk{% endif %} \
    passphrase="{{ wifi_passphrases[name] }}" \
    comment="kit:wifi:{{ name }}:security"
{% endif %}
{% endfor %}

# ── Virtual APs ──────────────────────────────────────────────────────────────
{% for name, seg in segments.items() %}
{% if seg.has_wifi %}
{% if '5ghz' in seg.wifi_bands %}
/interface wifi
add name=wifi-{{ name }}-5g \
    master-interface=wifi1 \
    configuration.ssid="{{ seg.ssid }}" \
    configuration.hide-ssid={{ 'yes' if seg.ssid_hidden else 'no' }} \
    security=sec-{{ name }} \
    disabled=no \
    comment="kit:wifi:{{ name }}:ap-5g"
{% endif %}
{% if '2ghz' in seg.wifi_bands %}
/interface wifi
add name=wifi-{{ name }}-2g \
    master-interface=wifi2 \
    configuration.ssid="{{ seg.ssid }}" \
    configuration.hide-ssid={{ 'yes' if seg.ssid_hidden else 'no' }} \
    security=sec-{{ name }} \
    disabled=no \
    comment="kit:wifi:{{ name }}:ap-2g"
{% endif %}
{% endif %}
{% endfor %}

# ── Bridge port assignments (PVID maps each AP to its VLAN) ─────────────────
{% for name, seg in segments.items() %}
{% if seg.has_wifi %}
{% if '5ghz' in seg.wifi_bands %}
/interface bridge port
add bridge=bridge \
    interface=wifi-{{ name }}-5g \
    pvid={{ seg.vlan_id }} \
    comment="kit:wifi:{{ name }}:bridge-5g"
{% endif %}
{% if '2ghz' in seg.wifi_bands %}
/interface bridge port
add bridge=bridge \
    interface=wifi-{{ name }}-2g \
    pvid={{ seg.vlan_id }} \
    comment="kit:wifi:{{ name }}:bridge-2g"
{% endif %}
{% endif %}
{% endfor %}

# ── Untagged VLAN membership for virtual APs ─────────────────────────────────
{% for name, seg in segments.items() %}
{% if seg.has_wifi %}
/interface bridge vlan
set [find where vlan-ids={{ seg.vlan_id }}] \
    untagged={% if '5ghz' in seg.wifi_bands %}wifi-{{ name }}-5g{% endif %}{% if seg.wifi_bands | length == 2 %},{% endif %}{% if '2ghz' in seg.wifi_bands %}wifi-{{ name }}-2g{% endif %}

{% endif %}
{% endfor %}
