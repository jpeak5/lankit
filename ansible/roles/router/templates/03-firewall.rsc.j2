# 03-firewall.rsc — Inter-segment firewall rules
# Generated by lankit — do not edit directly
#
# Rule order (top-down, first match wins):
#   1. Accept established/related (defconf — already exists)
#   2. Drop invalid (defconf — already exists)
#   3. Client isolation (intra-segment drops, before permits)
#   4. Inter-segment permits (from permissions map)
#   5. DNS permits (all segments → DNS server)
#   6. Internet egress permits per segment
#   7. Default inter-segment deny (catch-all, logged)
#   8. Scoped fasttrack (internet-only, replaces defconf blanket)
#   9. NAT masquerade for all VLAN subnets

# ── Remove previously managed entries (idempotent re-apply) ─────────────────
:foreach i in=[/ip firewall filter find where comment~"^lanlankit:"] do={ /ip firewall filter remove $i }
:foreach i in=[/ip firewall mangle find where comment~"^lanlankit:fw:"] do={ /ip firewall mangle remove $i }
:foreach i in=[/ip firewall nat find where comment~"^lanlankit:nat:"] do={ /ip firewall nat remove $i }
:foreach i in=[/ip firewall address-list find where comment~"^lanlankit:fw:"] do={ /ip firewall address-list remove $i }
:foreach i in=[/interface list member find where comment~"^lanlankit:fw:"] do={ /interface list member remove $i }

# ── Add VLAN interfaces to LAN list ─────────────────────────────────────────
# The defconf input rules accept LAN traffic. Without this, VLAN
# traffic is dropped before it reaches our rules.
/interface list member
{% for name in segments %}
add list=LAN \
    interface=vlan-{{ name }} \
    comment="lankit:fw:{{ name }}:lan-member"
{% endfor %}

# ── Address lists ────────────────────────────────────────────────────────────
/ip firewall address-list
{% for name, seg in segments.items() %}
add list=net-{{ name }} \
    address={{ seg.subnet }} \
    comment="lankit:fw:{{ name }}:address-list"
{% endfor %}
{% if include_globals %}
add list=all-local \
    address=10.0.0.0/8 \
    comment="lankit:fw:all:local-rfc1918"
add list=all-local \
    address=192.168.88.0/24 \
    comment="lankit:fw:all:local-flat"

# ── Connection mark: internet-bound traffic ──────────────────────────────────
# Used to scope fasttrack to internet-only, not inter-segment.
/ip firewall mangle
add chain=forward \
    action=mark-connection \
    new-connection-mark=internet-traffic \
    passthrough=yes \
    src-address-list=all-local \
    dst-address-list=!all-local \
    comment="lankit:fw:all:mark-internet"
{% endif %}

/ip firewall filter

# ── Client isolation (must be before permits) ────────────────────────────────
{% for name, seg in segments.items() %}
{% if seg.client_isolation %}
add chain=forward \
    action=drop \
    src-address-list=net-{{ name }} \
    dst-address-list=net-{{ name }} \
    log=yes log-prefix="{{ name }}-iso" \
    comment="lankit:fw:{{ name }}:isolation"
{% endif %}
{% endfor %}

# ── Inter-segment permits (from permissions map) ─────────────────────────────
{% for src, perm in permissions.items() %}
{% for dst in perm.can_reach %}
add chain=forward \
    action=accept \
    src-address-list=net-{{ src }} \
    dst-address-list=net-{{ dst }} \
    connection-state=new \
    comment="lankit:fw:{{ src }}>{{ dst }}:permit"
{% endfor %}
{% endfor %}

# ── DNS permit: all segments → DNS server ────────────────────────────────────
# Segments with dns=filtered or dns=unfiltered need to reach the local server.
# Skipped when no Pi-hole host — internet egress rules already cover public DNS.
{% if dns_server_segment is not none %}
{% for name, seg in segments.items() %}
{% if seg.dns != 'none' %}
add chain=forward \
    action=accept \
    src-address-list=net-{{ name }} \
    dst-address={{ dns_server_ip }} \
    dst-port=53 protocol=udp \
    comment="lankit:fw:{{ name }}>dns:permit-udp"
add chain=forward \
    action=accept \
    src-address-list=net-{{ name }} \
    dst-address={{ dns_server_ip }} \
    dst-port=53 protocol=tcp \
    comment="lankit:fw:{{ name }}>dns:permit-tcp"
{% endif %}
{% endfor %}
{% endif %}

# ── Internet egress per segment ───────────────────────────────────────────────
{% for name, seg in segments.items() %}
{% if seg.internet in ['full', 'egress_only'] %}
add chain=forward \
    action=accept \
    src-address-list=net-{{ name }} \
    out-interface={{ wan_interface }} \
    comment="lankit:fw:{{ name }}:egress"
{% endif %}
{% endfor %}

{% if include_globals %}
# ── Default inter-segment deny (catch-all) ───────────────────────────────────
add chain=forward \
    action=drop \
    src-address-list=all-local \
    dst-address-list=all-local \
    connection-state=new \
    log=yes log-prefix="inter-seg-drop" \
    comment="lankit:fw:all:default-deny"

# ── Scoped fasttrack — internet-only ────────────────────────────────────────
# MANUAL STEP: disable the defconf fasttrack rule after importing this file.
#   /ip firewall filter disable [find where comment="defconf: fasttrack"]
add chain=forward \
    action=fasttrack-connection \
    connection-state=established,related \
    connection-mark=internet-traffic \
    hw-offload=yes \
    comment="lankit:fw:all:fasttrack-internet"

# ── NAT masquerade ───────────────────────────────────────────────────────────
/ip firewall nat
add chain=srcnat \
    action=masquerade \
    src-address=10.0.0.0/8 \
    out-interface={{ wan_interface }} \
    ipsec-policy=out,none \
    comment="lankit:nat:all:masquerade"
{% endif %}
